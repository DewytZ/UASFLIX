<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>UASFlix</title>

<style>
:root {
    --bg: #141414;
    --card: #222;
    --text: #fff;
    --primary: #e50914;
    --accent: #d4a017;
    --border: rgba(0,0,0,0.6);
}

/* tema claro */
.light-theme {
    --bg: #f5f5dc;
    --card: #fff;
    --text: #1a1a1a;
    --primary: #003366;
    --accent: #d4a017;
    --border: rgba(0,0,0,0.4);
}

body {
    margin: 0;
    font-family: Arial;
    background: var(--bg);
    color: var(--text);
}

/* HEADER */
header {
    background: var(--primary);
    padding: 15px;
    display: flex;
    justify-content: space-between;
}

.logo {
    color: var(--accent);
    font-size: 28px;
    font-weight: bold;
}

.theme-btn {
    background: var(--accent);
    border: none;
    padding: 8px 15px;
    cursor: pointer;
    border-radius: 6px;
}

/* CONTENEDOR VIDEO */
.video-wrapper {
    position: relative;
    max-width: 900px;
    margin: 30px auto;
}

.video-container {
    position: relative;
    padding-bottom: 56.25%;
    border-radius: 15px;
    overflow: hidden;
    border: 2px solid var(--border);
}

.video-container iframe {
    position: absolute;
    width: 100%;
    height: 100%;
}

/* 🔥 BOTON INFO */
.info-btn {
    position: absolute;
    left: -60px;
    top: 50%;
    transform: translateY(-50%);
    background: var(--accent);
    color: black;
    padding: 10px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
}

/* 📋 PANEL */
.info-panel {
    position: absolute;
    left: -300px;
    top: 0;
    width: 260px;
    height: 100%;
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 15px;
    padding: 15px;
    transition: 0.4s;
}

/* abierto */
.info-panel.active {
    left: -280px;
}

.info-panel h3 {
    margin-top: 0;
}

/* CONTENIDO GENERAL */
.container {
    max-width: 900px;
    margin: auto;
    padding: 20px;
}

/* estrellas */
.stars {
    display: flex;
    font-size: 30px;
}

.star {
    color: gray;
    cursor: pointer;
}

.star.hover,
.star.selected {
    color: var(--accent);
}

/* comentarios */
textarea {
    width: 100%;
    background: var(--card);
    color: var(--text);
    border: 2px solid var(--border);
    padding: 10px;
    border-radius: 10px;
}

button {
    margin-top: 10px;
    padding: 10px;
    background: var(--primary);
    color: white;
    border: none;
    cursor: pointer;
}

.comment {
    background: var(--card);
    margin-top: 10px;
    padding: 10px;
    border-radius: 12px;
    border: 2px solid var(--border);
}

.comment-stars {
    color: var(--accent);
}
</style>
</head>

<body>

<header>
    <div class="logo">UASFLIX</div>
    <button class="theme-btn" onclick="toggleTheme()">Tema</button>
</header>

<!-- VIDEO + INFO -->
<div class="video-wrapper">

    <div class="info-btn" onclick="toggleInfo()">Info</div>

    <div class="info-panel" id="infoPanel">
        <h3>Información</h3>
        <p><b>Descripción:</b> Video de ejemplo tipo plataforma streaming.</p>
        <p><b>Fecha:</b> 2024</p>
        <p><b>Calificación media:</b> <span id="avg">0</span> ⭐</p>
    </div>

    <div class="video-container">
        <iframe src="https://www.youtube.com/embed/ptc4Awb0UpU"></iframe>
    </div>

</div>

<div class="container">

<h2>Califica</h2>

<div class="stars" id="stars">
    <span class="star">★</span>
    <span class="star">★</span>
    <span class="star">★</span>
    <span class="star">★</span>
    <span class="star">★</span>
</div>

<h2>Comentario</h2>
<textarea id="commentInput"></textarea>
<button onclick="addComment()">Publicar</button>

<div id="commentList"></div>

</div>

<script>
let rating = 0;
let total = 0;
let count = 0;

const stars = document.querySelectorAll(".star");

/* estrellas */
stars.forEach((star, index) => {

    star.addEventListener("mouseover", () => {
        resetStars();
        for (let i = 0; i <= index; i++) {
            stars[i].classList.add("hover");
        }
    });

    star.addEventListener("click", () => {
        rating = index + 1;
        setSelected(rating);
    });
});

document.getElementById("stars").addEventListener("mouseleave", () => {
    resetStars();
    setSelected(rating);
});

function resetStars() {
    stars.forEach(s => {
        s.classList.remove("hover");
        s.classList.remove("selected");
    });
}

function setSelected(value) {
    for (let i = 0; i < value; i++) {
        stars[i].classList.add("selected");
    }
}

/* comentarios + promedio */
function addComment() {
    const text = document.getElementById("commentInput").value.trim();

    if (!text || rating === 0) return;

    total += rating;
    count++;
    document.getElementById("avg").innerText = (total / count).toFixed(1);

    const div = document.createElement("div");
    div.classList.add("comment");

    div.innerHTML = `
        <div class="comment-stars">${"★".repeat(rating)}</div>
        <div>${text}</div>
    `;

    document.getElementById("commentList").appendChild(div);

    document.getElementById("commentInput").value = "";
    rating = 0;
    resetStars();
}

/* panel info */
function toggleInfo() {
    document.getElementById("infoPanel").classList.toggle("active");
}

/* tema */
function toggleTheme() {
    document.body.classList.toggle("light-theme");
}
</script>

</body>
</html>
